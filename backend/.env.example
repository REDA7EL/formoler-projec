# ════════════════════════════════════════
#  WhatsApp Campaign Manager — Environment
# ════════════════════════════════════════
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.

# ─── Server ──────────────────────────────
PORT=3001

# ─── WhatsApp Business Cloud API ─────────
# Get these from: Meta Developer Dashboard → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token_here
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_WABA_ID=your_waba_id_here

# Webhook verify token — choose any secret string
WHATSAPP_VERIFY_TOKEN=my_secret_verify_token

# ─── Encryption ──────────────────────────
# Random 32-char string used to encrypt the token in DB
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex').slice(0,32))"
ENCRYPT_KEY=formoler-whatsapp-secret-key-32x

# ─── Delay between messages (ms) ─────────
WHATSAPP_DELAY_MS=1000
